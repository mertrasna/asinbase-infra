# Local .terraform directories — provider binaries, modules cache
**/.terraform/*

# State files — these contain everything Terraform knows, including potentially sensitive data
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# tfvars files — these contain real values, often sensitive (account IDs, IPs, domains)
*.tfvars
*.tfvars.json
# But DO commit example files so users know what variables exist
!*.tfvars.example
!example.tfvars

# Override files — local-only customizations
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Editor / OS junk
.DS_Store
.vscode/
.idea/
*.swp
*.swo

infrastructure_map.md